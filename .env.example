# Skopíruj na .env a doplň reálne hodnoty:  cp .env.example .env
# .env je v .gitignore / .dockerignore — NIKDY ho necommituj.

# --- Database (lokálny dev beží cez compose, hodnoty sedia s compose.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
DB_HOST=db
RAILS_MAX_THREADS=5

# --- Redis (Sidekiq broker + cache) ---
REDIS_URL=redis://redis:6379/1

# --- Elasticsearch / Searchkick ---
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- Stripe (platby) ---
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Twilio (SMS notifikácie) ---
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+421xxx

# --- OpenWeatherMap (predpoveď počasia) ---
OPENWEATHER_API_KEY=xxx

# --- AWS S3 / Cloudflare R2 (ActiveStorage v produkcii) ---
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=eu-central-1
AWS_S3_BUCKET=chatahub

# --- Produkčná DB (iba v produkcii, viď config/database.yml) ---
CHATA_HUB_DATABASE_PASSWORD=
